#include <stdio.h>

void disp_count_sum14()
{
    int i = 1, temp, sum, count = 0;

    while(i < 100000)
    {
        temp = i;
        sum = 0;

        while(temp > 0)
        {
            sum = sum + (temp % 10);
            temp = temp / 10;
        }

        if(sum == 14)
            count++;

        i++;
    }

    printf("%d", count);
}

int main()
{
    disp_count_sum14();
}
