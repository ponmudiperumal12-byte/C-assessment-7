#include <stdio.h>

void check_prime(int n)
{
    int i = 2, count = 0;

    while(i < n)
    {
        if(n % i == 0)
            count++;

        i++;
    }

    if(n > 1 && count == 0)
        printf("Prime");
    else
        printf("Not Prime");
}

int main()
{
    int n;
    printf ("enter the number:");
    scanf("%d", &n);

    check_prime(n);
}
