#include <stdio.h>

void disp_single_digit_Square(int n)
{
    int digit, count = 0;

    while(n > 0)
    {
        digit = n % 10;

        if(digit == 0 || digit == 1 || digit == 4 || digit == 9)
            count++;

        n = n / 10;
    }

    printf("%d", count);
}

int main()
{
    int n;
    printf ("enter the number:");
    scanf("%d", &n);

    disp_single_digit_Square(n);
}
