#include <stdio.h>

void disp_total_2digit_Square(int n)
{
    int num, count = 0;

    while(n >= 10)
    {
        num = n % 100;

        if(num == 16 || num == 25 || num == 36 || num == 49 ||
           num == 64 || num == 81)
        {
            count++;
        }

        n = n / 10;
    }

    printf("%d", count);
}

int main()
{
    int n;
    printf ("enter the number:");
    scanf("%d", &n);

    disp_total_2digit_Square(n);
}
