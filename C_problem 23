#include <stdio.h>

void disp_total_2digit_odd(int n)
{
    int num, count = 0;

    while(n >= 10)
    {
        num = n % 100;

        if(num >= 10 && num % 2 != 0)
            count++;

        n = n / 10;
    }

    printf("%d", count);
}

int main()
{
    int n;
    printf ("enter the number:");
    scanf("%d", &n);

    disp_total_2digit_odd(n);
}
