#include <stdio.h>

void disp_interchange_first_last_digit()
{
    int n,f, l, m, temp;
    printf ("enter the number:");
    scanf("%d", &n);
    l = n % 10;
    temp = n;
    while(temp >= 10)
        temp = temp / 10;

    f = temp;

    m = (n % 1000) / 10;

    printf("%d%d%d", l, m, f);
}

int main()
{
    disp_interchange_first_last_digit();
}
